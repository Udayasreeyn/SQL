SELECT * FROM vips LIMIT 5;
SELECT * FROM reservations LIMIT 5;
SELECT * FROM events LIMIT 5;
SELECT * FROM hotels LIMIT 5;

-- 1. [INNER JOIN] Show all VIPs and the type of event they are attending.
SELECT vips.last_name
, vips.first_name
, events.event_type
FROM vips
JOIN events
ON vips.event = events.event_id
;

-- 2. [INNER JOIN and FILTERING] Show VIPs who are attending keynote events only

SELECT vips.last_name
, vips.first_name
, events.event_name
, events.event_type 
FROM vips
JOIN events
ON vips.event = events.event_id
WHERE events.event_type = 'Keynote'
;

-- 3. [Multiple JOINs] Show VIPs and the hotel they are staying in

SELECT vips.last_name
, vips.first_name
, hotels.hotel_name
FROM vips
JOIN reservations
ON vips.member_id = reservations.member_id
JOIN hotels
ON reservations.hotel = hotels.hotel_id
;

-- 4. [LEFT JOIN] Show all VIPs and whether they RSVP’d to the welcome party (include VIPs even if no reservation exists)

SELECT vips.last_name
, vips.first_name
, CASE 
    WHEN reservations.welcome_rsvp = 1 THEN 'yes'
    WHEN reservations.welcome_rsvp = 0 THEN 'no'
    ELSE 'no response'
   END AS welcome_response
FROM vips
LEFT JOIN reservations
ON vips.member_id = reservations.member_id
;

-- 5. [SELF JOIN] Show which VIP gives feedback to which other VIP

SELECT v1.first_name AS reviewer_name
, v2.first_name AS reviewed_name
FROM vips v1
JOIN vips v2
ON v1.provides_feedback_to = v2.member_id
;

-- 6. [Multiple JOINS] Show VIPs attending workshops who also RSVP’d to dinner

SELECT vips.last_name
, vips.first_name
, events.event_type
FROM vips
JOIN events
ON vips.event = events.event_id
JOIN reservations
ON vips.member_id = reservations.member_id
WHERE events.event_type = 'Workshop' 
AND reservations.dinner_rsvp = 1
;












